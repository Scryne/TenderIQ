# TenderIQ — Ortam Değişkenleri (ŞABLON)
# Bu dosya gerçek sır İÇERMEZ. Kopyalayıp `.env` oluşturun ve doldurun.
#   cp .env.example .env
# .env dosyası .gitignore ile korunur; asla commit edilmez (gitleaks CI'da bekçi).

# ── Uygulama ────────────────────────────────────────────────────────────────
ENVIRONMENT=development            # development | staging | production
DEBUG=true
API_V1_PREFIX=/api/v1
CORS_ORIGINS=http://localhost:3000 # virgülle ayrılmış liste

# ── Veritabanı (PostgreSQL + pgvector) ───────────────────────────────────────
# Uygulama bağlantısı: RLS'ye TABİ, süper-kullanıcı OLMAYAN rol (compose oluşturur).
DATABASE_URL=postgresql+psycopg://tenderiq_app:tenderiq_app@localhost:5432/tenderiq
# Migration/DDL için ayrıcalıklı bağlantı (owner/superuser). Bkz. ADR-0003.
DATABASE_ADMIN_URL=postgresql+psycopg://tenderiq:tenderiq@localhost:5432/tenderiq

# ── Redis (Celery broker/backend + önbellek) ─────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Nesne Depolama (Cloudflare R2 / S3-uyumlu) ───────────────────────────────
OBJECT_STORAGE_ENDPOINT_URL=       # ör. https://<accountid>.r2.cloudflarestorage.com
OBJECT_STORAGE_BUCKET=tenderiq-documents
OBJECT_STORAGE_ACCESS_KEY_ID=
OBJECT_STORAGE_SECRET_ACCESS_KEY=
OBJECT_STORAGE_REGION=auto

# ── LLM (Anthropic Claude — birincil) ────────────────────────────────────────
ANTHROPIC_API_KEY=
LLM_PRIMARY_MODEL=claude-opus-4-8
# Zero-retention / no-training: sağlayıcı hesabı düzeyinde doğrulanır (§10.3).

# ── Gözlemlenebilirlik ───────────────────────────────────────────────────────
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
SENTRY_DSN=

# ── Kimlik Doğrulama ─────────────────────────────────────────────────────────
AUTH_SECRET=                       # `openssl rand -base64 32` ile üretin

# ── Frontend (apps/web) ──────────────────────────────────────────────────────
# Tarayıcıya gömülür (NEXT_PUBLIC_*). Backend API'nin tarayıcıdan erişilen kök adresi.
NEXT_PUBLIC_API_URL=http://localhost:8000

# ── Ödeme (Faz 3) ────────────────────────────────────────────────────────────
IYZICO_API_KEY=
IYZICO_SECRET_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
