# TenderIQ — Ortam Değişkenleri (ŞABLON)
# Bu dosya gerçek sır İÇERMEZ. Kopyalayıp `.env` oluşturun ve doldurun.
#   cp .env.example .env
# .env dosyası .gitignore ile korunur; asla commit edilmez (gitleaks CI'da bekçi).

# ── Uygulama ────────────────────────────────────────────────────────────────
ENVIRONMENT=development            # development | staging | production
DEBUG=true
API_V1_PREFIX=/api/v1
CORS_ORIGINS=http://localhost:3000 # virgülle ayrılmış liste

# ── Veritabanı (PostgreSQL + pgvector) ───────────────────────────────────────
# Uygulama bağlantısı: RLS'ye TABİ, süper-kullanıcı OLMAYAN rol (compose oluşturur).
DATABASE_URL=postgresql+psycopg://tenderiq_app:tenderiq_app@localhost:5432/tenderiq
# Migration/DDL için ayrıcalıklı bağlantı (owner/superuser). Bkz. ADR-0003.
DATABASE_ADMIN_URL=postgresql+psycopg://tenderiq:tenderiq@localhost:5432/tenderiq

# ── Redis (Celery broker/backend + önbellek) ─────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Nesne Depolama (Cloudflare R2 / S3-uyumlu) ───────────────────────────────
OBJECT_STORAGE_ENDPOINT_URL=       # ör. https://<accountid>.r2.cloudflarestorage.com
OBJECT_STORAGE_BUCKET=tenderiq-documents
OBJECT_STORAGE_ACCESS_KEY_ID=
OBJECT_STORAGE_SECRET_ACCESS_KEY=
OBJECT_STORAGE_REGION=auto

# ── LLM (Sprint 2.2 çıkarım ajanları) ────────────────────────────────────────
# "nvidia" (NVIDIA NIM bulut, NVIDIA_API_KEY zorunlu; ücretsiz güçlü modeller —
# dev kalitesi için önerilir) | "anthropic" (ANTHROPIC_API_KEY zorunlu; yayın
# birincil) | "ollama" (yerel, anahtarsız) | "none" (ajanlar kapalı; testler/CI).
LLM_PROVIDER=nvidia
# NVIDIA NIM (integrate.api.nvidia.com/v1) — build.nvidia.com'dan nvapi-... anahtarı.
# Şema zorlaması response_format=json_schema; geniş bağlam penceresi. KVKK: BULUT —
# doküman içeriği NVIDIA'ya gider (production gerçek şartname için DPA gerekir).
NVIDIA_API_KEY=
NVIDIA_MODEL=qwen/qwen3.5-122b-a10b
ANTHROPIC_API_KEY=
LLM_PRIMARY_MODEL=claude-opus-4-8
LLM_MAX_OUTPUT_TOKENS=16000
# Şema zorlaması: uymayan çıktının yeniden istenme tavanı (ADR-0006 zinciri).
LLM_SCHEMA_MAX_ATTEMPTS=3
# Zero-retention / no-training: sağlayıcı hesabı düzeyinde doğrulanır (§10.3).
# Yerel geliştirme için Ollama (LLM_PROVIDER=ollama): anahtar gerekmez.
# `ollama pull qwen2.5:7b-instruct-q5_K_M` ile modeli indir; sunucu localhost:11434.
# NOT: Küçük yerel modeller Türkçe birebir grounding'de zayıftır — golden-set
# kalite kapısını (Faz 2 çıkış) yine Claude ile ölç.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b-instruct-q5_K_M
# Bağlam penceresi: Ollama varsayılanı (4096) uzun bağlamı sessizce kırpar ve
# grounding'i bozar. 8192 tam ajan bağlamını tutar (q5 modelle 8GB VRAM'e sığar).
OLLAMA_NUM_CTX=8192
# Tek çağrının azami çıktı token'ı. Claude tavanı (16000) yerel modelde çok yavaş
# ve "başıboş üretim"e yol açar; 4096 tipik çıkarıma yeter ve çağrıyı sınırlar.
OLLAMA_NUM_PREDICT=4096

# ── Gözlemlenebilirlik ───────────────────────────────────────────────────────
# Langfuse LLM tracing (Sprint 2.4): anahtarlar boşsa tracing tamamen no-op
# (langfuse hiç import edilmez). Doldurulunca her LLM çağrısı (qwen dahil) trace
# edilir: model/gecikme/token. Kurulum: `uv sync --extra langfuse`.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
# KVKK / zero-retention (§10.3): getirilen bağlam DOKÜMAN İÇERİĞİDİR. false →
# Langfuse'a yalnız metadata gider (istem/çıktı GİTMEZ). Yalnız SELF-HOSTED
# Langfuse'da true yapılmalı (doküman içeriği dış buluta sızmasın).
LANGFUSE_CAPTURE_IO=false
SENTRY_DSN=
# Web (tarayıcı + Next sunucusu) için ayrı DSN; boşsa Sentry tamamen kapalı.
NEXT_PUBLIC_SENTRY_DSN=

# ── Kimlik Doğrulama ─────────────────────────────────────────────────────────
AUTH_SECRET=                       # `openssl rand -base64 32` ile üretin
# Güvenilir ters-proxy sayısı: X-Forwarded-For'un sondan kaç girdisi güvenilir
# altyapıdan (Next proxy / LB) gelir. 0 = XFF yok sayılır. Compose api servisi 1 kullanır.
TRUSTED_PROXY_COUNT=0
# Oran sınırlama (varsayılanlar): e-posta 5 / IP 20 deneme, 300 sn pencere.
AUTH_RATE_LIMIT_ATTEMPTS=5
AUTH_RATE_LIMIT_IP_ATTEMPTS=20
AUTH_RATE_LIMIT_WINDOW_SECONDS=300

# ── Yükleme & Parsing (Sprint 1.1/1.2) ───────────────────────────────────────
UPLOAD_MAX_SIZE_BYTES=104857600    # 100 MB
UPLOAD_PENDING_TTL_HOURS=24        # yarım kalan yüklemeler bu süreden sonra failed
PARSING_OCR_LANGUAGES=tr,en        # EasyOCR dil listesi (virgülle ayrılmış)

# ── Getirim (Sprint 2.1, ADR-0012) ───────────────────────────────────────────
# Reranker: local (cross-encoder, yalnız worker'da gerekir) | none (RRF sırası korunur).
RETRIEVAL_RERANKER_PROVIDER=local
RETRIEVAL_RERANKER_MODEL=BAAI/bge-reranker-v2-m3
# Aday/eşik ayarları (varsayılanlar): RETRIEVAL_SEMANTIC_TOP_K=24, RETRIEVAL_KEYWORD_TOP_K=24,
# RETRIEVAL_RRF_K=60, RETRIEVAL_RERANK_CANDIDATES=32, RETRIEVAL_TOP_N=8,
# RETRIEVAL_AGENT_CONTEXT_LIMIT=12 — kalibrasyon Sprint 2.4 golden-set kapısında.

# ── Frontend (apps/web) ──────────────────────────────────────────────────────
# Tarayıcıya gömülür (NEXT_PUBLIC_*). Backend API'nin tarayıcıdan erişilen kök adresi.
NEXT_PUBLIC_API_URL=http://localhost:8000

# ── E-posta / hesap yaşam döngüsü (Sprint 3.3-D/E) ───────────────────────────
# "logging" (dev: gönderim yok, bağlantı loglanır) | gerçek sağlayıcı (prod).
EMAIL_PROVIDER=logging
EMAIL_FROM=no-reply@tenderiq.local
# Doğrulama/sıfırlama/davet bağlantılarının işaret ettiği web tabanı.
APP_BASE_URL=http://localhost:3000
# Tek-kullanımlık token ömürleri (saat).
EMAIL_VERIFY_TOKEN_TTL_HOURS=24
PASSWORD_RESET_TOKEN_TTL_HOURS=1
INVITATION_TOKEN_TTL_HOURS=72

# ── Ödeme / abonelik (Sprint 3.3-B) ──────────────────────────────────────────
# "manual" (dev/test: harici ağ geçidi yok — yükseltme anında etkinleşir; webhook
# yolu HMAC imzayla gerçek ve idempotent) | "iyzico"/"paytr"/"stripe" (gerçek
# sağlayıcı; adaptör + sandbox/canlı anahtarları aynı seam'e eklenir).
BILLING_PROVIDER=manual
# Webhook imza sırrı (HMAC-SHA256). Gerçek sağlayıcıda sağlayıcının webhook sırrı.
BILLING_WEBHOOK_SECRET=
