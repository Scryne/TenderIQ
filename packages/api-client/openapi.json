          "bbox_x0": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "null"
              }
            ],
            "title": "Bbox X0"
          },
          "bbox_x1": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "null"
              }
            ],
            "title": "Bbox X1"
          },
          "bbox_y0": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "null"
              }
            ],
            "title": "Bbox Y0"
          },
          "bbox_y1": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "null"
              }
            ],
            "title": "Bbox Y1"
          },
          "element_id": {
            "format": "uuid",
            "title": "Element Id",
            "type": "string"
          },
          "element_seq": {
            "title": "Element Seq",
            "type": "integer"
          },
          "page": {
            "title": "Page",
            "type": "integer"
          },
          "quote": {
            "title": "Quote",
            "type": "string"
          },
          "resolution": {
            "$ref": "#/components/schemas/GroundingResolution"
          },
          "section": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Section"
          }
        },
        "required": [
          "element_id",
          "element_seq",
          "page",
          "section",
          "bbox_x0",
          "bbox_y0",
          "bbox_x1",
          "bbox_y1",
          "quote",
          "resolution"
        ],
        "title": "FindingSource",
        "type": "object"
      },
      "GroundingResolution": {
