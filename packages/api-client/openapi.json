            "anyOf": [
              {
                "$ref": "#/components/schemas/JobResponse"
              },
              {
                "type": "null"
              }
            ]
          }
        },
        "required": [
          "document",
          "job"
        ],
        "title": "DocumentCompleteResponse",
        "type": "object"
      },
      "DocumentCreate": {
