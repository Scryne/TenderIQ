{
  "components": {
    "schemas": {
      "DeliverableKind": {
        "description": "Sunulacak belge tipi (§8.1 ``Deliverable``).",
        "enum": [
          "document",
          "certificate",
          "guarantee",
          "other"
        ],
        "title": "DeliverableKind",
        "type": "string"
      },
      "DeliverableResponse": {
        "description": "Çıkarılmış istenen belge (kaynaklı).",
