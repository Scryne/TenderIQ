          "document_id": {
            "format": "uuid",
            "title": "Document Id",
            "type": "string"
          },
          "id": {
            "format": "uuid",
            "title": "Id",
            "type": "string"
          },
          "is_mandatory": {
            "title": "Is Mandatory",
            "type": "boolean"
          },
          "kind": {
            "$ref": "#/components/schemas/DeliverableKind"
          },
          "name": {
            "title": "Name",
            "type": "string"
          },
          "source": {
            "$ref": "#/components/schemas/FindingSource"
          }
        },
        "required": [
          "id",
          "document_id",
          "name",
          "kind",
          "is_mandatory",
          "source"
        ],
        "title": "DeliverableResponse",
        "type": "object"
      },
      "DocumentCompleteResponse": {
        "description": "Tamamlanan yükleme: güncel doküman + kuyruğa alınan iş.",
        "properties": {
