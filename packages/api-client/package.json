{
  "name": "@tenderiq/api-client",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "TenderIQ API'sinin OpenAPI'dan üretilen tip-güvenli TypeScript istemcisi.",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "scripts": {
    "generate": "openapi-typescript ./openapi.json -o ./src/schema.d.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "openapi-fetch": "^0.13.4"
  },
  "devDependencies": {
    "openapi-typescript": "^7.5.0",
    "typescript": "^5.7.2"
  }
}
